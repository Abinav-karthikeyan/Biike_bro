# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=CHANGE_ME_IN_PRODUCTION

# CORS — add your frontend origin here
CORS_ORIGINS=["http://localhost:3000","http://localhost:5500","http://127.0.0.1:5500"]

# ── Database ──────────────────────────────────────────────────────────────────
# For local dev (without Docker): change host to localhost
DATABASE_URL=postgresql+asyncpg://buddy:buddy@localhost:5432/cycle_buddy
DATABASE_POOL_SIZE=10

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
ZONE_CACHE_TTL_SECONDS=300

# ── GBFS Feed URLs ────────────────────────────────────────────────────────────
# Add your operator GBFS auto-discovery URLs here (comma-separated JSON array)
# Examples:
#   Lime:  https://data.lime.bike/api/partners/v1/gbfs/london/gbfs.json
#   Voi:   https://api.voiapp.io/v1/gbfs/london/gbfs.json
#   Tier:  https://platform.tier-services.io/gbfs/london/gbfs.json
GBFS_FEED_URLS=[]
GBFS_POLL_INTERVAL_SECONDS=300

# ── ML Model Artifacts ────────────────────────────────────────────────────────
MODEL_ARTIFACTS_S3_BUCKET=your-s3-bucket-name
MODEL_ARTIFACTS_PATH=models/
PREDICTION_LOOKAHEAD_30_MIN_THRESHOLD=0.78

# ── HNSW Index ────────────────────────────────────────────────────────────────
HNSW_INDEX_PATH=data/hnsw_indices/
HNSW_M=16
HNSW_EF_CONSTRUCTION=200
HNSW_EF_SEARCH=50

# ── On-device SLM ─────────────────────────────────────────────────────────────
# Fine-tuned via QLoRA; runs on-device; no cloud inference calls
SLM_MODEL_NAME=Qwen/Qwen2.5-0.5B-Instruct
SLM_MAX_LATENCY_MS=200
